== Просмотр кода с пояснениями ==
=== Полный код (.nlogo) ===

<syntaxhighlight lang="lisp" line>
;; ============================================
;; SIMPLE ECONOMY
;; Из учебника "Introduction to Agent-Based Modeling"
;; Ури Виленский, Уильям Рэнд
;; ============================================
;; ОПИСАНИЕ:
;; Простейшая модель экономического обмена.
;; Каждый агент начинает с одинаковым богатством.
;; На каждом шаге агент с деньгами отдаёт 1 доллар
;; случайному агенту.
;; ============================================

turtles-own [
  wealth            ;; богатство агента (доллары)
]

;; ============================================
;; НАСТРОЙКА МИРА
;; ============================================

to setup
  clear-all
  
  ;; Создаём агентов с одинаковым начальным богатством
  create-turtles num-agents [
    set wealth initial-wealth     ;; все получают поровну (100 долларов)
    setxy wealth 0                ;; позиция по X = богатство (богатые правее)
    set size 1.5                  ;; размер точки на экране
    set color blue                ;; все синие
  ]
  
  reset-ticks
end

;; ============================================
;; ГЛАВНЫЙ ЦИКЛ (1 тик = 1 раунд обмена)
;; ============================================

to go
  ask turtles [
    if wealth > 0 [
      ;; Агент отдаёт 1 доллар
      set wealth wealth - 1
      
      ;; Случайно выбираем получателя среди всех агентов
      ask one-of other turtles [
        set wealth wealth + 1    ;; получатель получает 1 доллар
      ]
    ]
    
    ;; Двигаем агента: позиция = текущее богатство
    ;; Богатые уходят вправо, бедные влево
    set xcor wealth
  ]
  
  tick
end

